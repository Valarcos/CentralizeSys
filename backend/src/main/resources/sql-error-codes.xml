<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="sQLite" class="org.springframework.jdbc.support.SQLErrorCodes">
        <property name="databaseProductName" value="SQLite"/>
        <property name="useSqlStateForTranslation" value="false" />

        <property name="dataIntegrityViolationCodes">
            <list>
                <value>19</value>
                <value>2067</value> <value>787</value>  <value>1555</value> </list>
        </property>

        <property name="badSqlGrammarCodes">
            <list>
                <value>1</value>
            </list>
        </property>
    </bean>

</beans>