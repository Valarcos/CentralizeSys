########################################
#   JAVA + KOTLIN + GRADLE PROJECT     #
#   CLEAN, MAINTAINABLE, THESIS-READY  #
########################################

########## GRADLE BUILD SYSTEM #########
# Ignore Gradle cache and build outputs
.gradle/
build/
.gradletasknamecache

############ JVM / COMPILATION #########
*.class
# Ignore archive files (prevents accidental library commits)
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# Keep only the Gradle wrapper JAR (required for builds)
# Added below .jar for exception to work
!backend/gradle/wrapper/gradle-wrapper.jar

hs_err_pid*           # JVM crash logs
replay_pid*           # JVM replay logs

# ============================
# Local data files (Excel, SQLite, backups, etc.)
# ============================
data/*
!data/.gitkeep

# Avoid committing any SQLite database files anywhere
*.db
*.sqlite
*.sqlite3
*.db-journal

################# LOGS ##################
*.log
logs/

############### INTELLIJ IDEA ##########
# Ignore entire .idea folder — user-specific files,
# regenerated automatically, avoids merge conflicts
.idea/

# IntelliJ compilation output
out/
# Legacy IntelliJ files
*.iml
*.ipr
*.iws

############### VS CODE ################
.vscode/

############### SONARCLOUD / SONARQUBE #
# Ignore local scanner caches and generated files
.sonarqube/
.scannerwork/
.sonar/

############### KOTLIN ##################
# No special rules needed — Kotlin plugin stores
# data in .idea/ or .gradle/, both ignored above.

############ OPERATING SYSTEM FILES ####
# Windows
Thumbs.db
desktop.ini

# macOS
.DS_Store

# Linux temporary files
*~

######## CREDENTIALS & ENV FILES #######
.env
.env.*
*.key
*.pem
*.crt
*.p12
*.jks
google-credentials.json
google-service-account.json

########## LOCAL BACKUPS ################
# System will generate local DB backups — ignore them
/backup/
/backups/
/local-backups/
/db-backups/

############# TEMPORARY FILES ###########
# Excel temporary lock files
~$*.xlsx
*.tmp
*.bak

########################################
#      END OF GITIGNORE                #
########################################