########################################
#   JAVA + KOTLIN + GRADLE PROJECT     #
#   CLEAN, MAINTAINABLE, THESIS-READY  #
########################################

########## GRADLE BUILD SYSTEM #########
# Ignore Gradle cache and build outputs
.gradle/
build/
.gradletasknamecache

############ JVM / COMPILATION #########
*.class
# Ignore archive files (prevents accidental library commits)
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# Keep only the Gradle wrapper JAR (required for builds)
# Added below .jar for exception to work
!backend/gradle/wrapper/gradle-wrapper.jar

hs_err_pid*           # JVM crash logs
replay_pid*           # JVM replay logs

# ============================
# Local data files (Excel, SQLite, backups, etc.)
# ============================
data/*
!data/.gitkeep

# Avoid committing any SQLite database files anywhere
*.db
*.sqlite
*.sqlite3
*.db-journal

################# LOGS ##################
*.log
logs/

############### INTELLIJ IDEA ##########
# Ignore entire .idea folder — user-specific files,
# regenerated automatically, avoids merge conflicts
.idea/

# IntelliJ compilation output
out/
# Legacy IntelliJ files
*.iml
*.ipr
*.iws

############### VS CODE ################
.vscode/

############### SONARCLOUD / SONARQUBE #
# Ignore local scanner caches and generated files
.sonarqube/
.scannerwork/
.sonar/

############### KOTLIN ##################
# No special rules needed — Kotlin plugin stores
# data in .idea/ or .gradle/, both ignored above.

############ OPERATING SYSTEM FILES ####
# Windows
Thumbs.db
desktop.ini

# macOS
.DS_Store

# Linux temporary files
*~

######## CREDENTIALS & ENV FILES #######
.env
.env.*
!*.example
!frontend/.env
!frontend/.env.production
# Exception: frontend/.env only has VITE_API_URL (non-secret)
# If you add secrets, use frontend/.env.local instead

*.key
*.pem
*.crt
*.p12
*.jks
google-credentials.json
google-service-account.json

########## LOCAL BACKUPS ################
# System will generate local DB backups — ignore them
/backup/
/backups/
/local-backups/
/db-backups/

############# TEMPORARY FILES ###########
# Excel temporary lock files
~$*.xlsx
*.tmp
*.bak

############# NODE.JS / NPM ##############
# Dependencies folder (regenerated from package-lock.json)
node_modules/

# Build output
dist/
build/

# Vite cache
.vite/

# ESLint cache
.eslintcache

# Local env files with secrets (but NOT package.json/lock!)
# NOTE: frontend/.env with VITE_API_URL is safe to commit
# If you have secrets, use .env.local instead
.env.local
.env.*.local

########################################
#      END OF GITIGNORE                #
########################################
geminiChats/