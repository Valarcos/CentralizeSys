<?xml version="1.0" encoding="UTF-8"?>
<!--
    SQLite Error Codes Translation for Spring JDBC

    This file maps SQLite error codes to Spring's DataAccessException hierarchy.
    Spring automatically loads this from classpath and uses it for exception translation.

    Reference: https://www.sqlite.org/rescode.html

    Format: SQLite error codes are mapped to Spring exception categories.
    When SQLite throws one of these codes, Spring wraps it in the corresponding exception type.
-->
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="customSQLiteErrorCodes" class="org.springframework.jdbc.support.SQLErrorCodes">
        <property name="databaseProductName" value="SQLite"/>
        <property name="useSqlStateForTranslation" value="false" />

        <!-- Data Integrity Violations → DataIntegrityViolationException → 400 Bad Request -->
        <property name="dataIntegrityViolationCodes">
            <list>
                <!-- CONSTRAINT violations (general category) -->
                <value>19</value>     <!-- SQLITE_CONSTRAINT: Generic constraint violation -->

                <!-- Specific constraint subtypes (extended error codes) -->
                <value>275</value>    <!-- SQLITE_CONSTRAINT_CHECK: CHECK constraint failed -->
                <value>531</value>    <!-- SQLITE_CONSTRAINT_FOREIGNKEY: FK violation (child table) -->
                <value>787</value>    <!-- SQLITE_CONSTRAINT_FOREIGNKEY: FK violation -->
                <value>1043</value>   <!-- SQLITE_CONSTRAINT_FUNCTION: Function constraint -->
                <value>1299</value>   <!-- SQLITE_CONSTRAINT_NOTNULL: NOT NULL constraint failed -->
                <value>1555</value>   <!-- SQLITE_CONSTRAINT_PRIMARYKEY: PK violation -->
                <value>2067</value>   <!-- SQLITE_CONSTRAINT_UNIQUE: UNIQUE constraint failed -->
                <value>2579</value>   <!-- SQLITE_CONSTRAINT_TRIGGER: Trigger constraint -->
            </list>
        </property>

        <!-- SQL Grammar Errors → BadSqlGrammarException → 500 (dev bug, not user error) -->
        <property name="badSqlGrammarCodes">
            <list>
                <value>1</value>      <!-- SQLITE_ERROR: SQL syntax error or missing database -->
            </list>
        </property>

        <!-- Database Locking → CannotAcquireLockException / DeadlockLoserDataAccessException -->
        <property name="deadlockLoserCodes">
            <list>
                <value>5</value>      <!-- SQLITE_BUSY: Database is locked (busy) -->
                <value>6</value>      <!-- SQLITE_LOCKED: A table in the database is locked -->
            </list>
        </property>

        <!-- Data Access Resource Failures → DataAccessResourceFailureException -->
        <property name="dataAccessResourceFailureCodes">
            <list>
                <value>10</value>     <!-- SQLITE_IOERR: Disk I/O error -->
                <value>11</value>     <!-- SQLITE_CORRUPT: Database disk image is malformed -->
                <value>13</value>     <!-- SQLITE_FULL: Database or disk is full -->
                <value>14</value>     <!-- SQLITE_CANTOPEN: Unable to open database file -->
                <value>26</value>     <!-- SQLITE_NOTADB: File is not a database -->
            </list>
        </property>

        <!-- Permission Errors → PermissionDeniedDataAccessException -->
        <property name="permissionDeniedCodes">
            <list>
                <value>3</value>      <!-- SQLITE_PERM: Access permission denied -->
                <value>23</value>     <!-- SQLITE_AUTH: Authorization denied -->
            </list>
        </property>

    </bean>

</beans>